rules_version = '2';

// All reads/writes for the admin console and the public /r/[slug] menu go
// through server-side code using the Firebase Admin SDK, which bypasses these
// rules entirely. This file only matters if a client ever talks to Firestore
// directly (currently nothing does — see src/lib/firebase-client.ts, which
// only exports `auth`), so it stays maximally restrictive by default.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
